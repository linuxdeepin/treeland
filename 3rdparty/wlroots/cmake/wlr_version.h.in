#ifndef WLR_VERSION_H
#define WLR_VERSION_H

#define WLR_VERSION_STR "@WLR_VERSION_STR@"
#define WLR_VERSION_MAJOR @WLR_VERSION_MAJOR@
#define WLR_VERSION_MINOR @WLR_VERSION_MINOR@
#define WLR_VERSION_MICRO @WLR_VERSION_MICRO@

#define WLR_VERSION_NUM ((WLR_VERSION_MAJOR << 16) | (WLR_VERSION_MINOR << 8) | WLR_VERSION_MICRO)

#endif
