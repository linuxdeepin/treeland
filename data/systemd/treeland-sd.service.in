[Unit]
Description=dde service
StartLimitBurst=3
CollectMode=inactive-or-failed

Requires=treeland-sd.socket
PartOf=treeland-sd.socket
After=treeland-sd.socket

Requires=dde-session.target
PartOf=dde-session.target

[Service]
Type=notify
Sockets=treeland-sd.socket
UnsetEnvironment=DISPLAY
UnsetEnvironment=WAYLAND_DISPLAY
ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/treeland
ExecStartPost=-/usr/bin/systemctl --user set-environment DDE_CURRENT_COMPOSITER=TreeLand
ExecStartPost=-/usr/bin/systemctl --user set-environment DDE_CURRENT_COMPOSITOR=TreeLand
ExecStopPost=-/usr/bin/systemctl --user unset-environment DDE_CURRENT_COMPOSITER
ExecStopPost=-/usr/bin/systemctl --user unset-environment DDE_CURRENT_COMPOSITOR
Slice=session.slice
Restart=on-failure
RestartSec=1s

