{
  "version": 4,
  "configurePresets": [
    {
      "name": "ci",
      "displayName": "CI Build Config",
      "description": "Build configuration with warnings as errors",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "$env{CXXFLAGS} -Wall -Wextra -Werror -Wno-error=stringop-overflow -Wno-sfinae-incomplete",
        "CMAKE_C_FLAGS": "$env{CFLAGS} -Wall -Wextra -Werror -Wno-error=stringop-overflow"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ci",
      "configurePreset": "ci",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ]
}
